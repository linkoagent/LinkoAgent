# --- Dominio ---
# En local dejar localhost. En producción: https://linkoagent.com
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# --- Base de datos (docker-compose levanta esto local) ---
DATABASE_URL="postgresql://linko:linko@localhost:5432/linko?schema=public"
# En Supabase: DATABASE_URL = "Transaction pooler" (puerto 6543, con ?pgbouncer=true),
# DIRECT_URL = "Direct connection" (puerto 5432). En local, dejar las dos iguales.
DIRECT_URL="postgresql://linko:linko@localhost:5432/linko?schema=public"

# --- NextAuth ---
# En producción usar https://linkoagent.com y generar un NEXTAUTH_SECRET nuevo
# (no reutilizar el de local): openssl rand -base64 32
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="reemplazar-con-un-secreto-largo-generado-con-openssl-rand-base64-32"

# --- IA: chat (Groq, capa gratuita sin tarjeta) ---
# Si se deja vacío, o AI_MOCK_MODE=true, el agente usa respuestas simuladas (sin llamar a
# Groq) para poder probar todo el flujo sin depender de una API key. Key gratis en
# console.groq.com — no pide tarjeta.
GROQ_API_KEY=""
GROQ_MODEL="llama-3.3-70b-versatile"
AI_MOCK_MODE="true"

# --- IA: embeddings / búsqueda semántica (Google Gemini, capa gratuita sin tarjeta) ---
# Mismo criterio: sin GOOGLE_API_KEY, la búsqueda en la Base de Conocimiento cae a un
# emparejamiento de palabras (sin significado real) en vez de similaridad semántica.
# Key gratis en aistudio.google.com — tampoco pide tarjeta.
GOOGLE_API_KEY=""
GOOGLE_EMBEDDING_MODEL="gemini-embedding-001"

# --- WhatsApp Cloud API (Meta) ---
# Igual que con la IA: si no hay accessToken cargado en el canal, o WHATSAPP_MOCK_MODE=true,
# el envio de mensajes queda simulado (se guarda igual, pero no llama a la Graph API real).
WHATSAPP_MOCK_MODE="true"
WHATSAPP_WEBHOOK_VERIFY_TOKEN="linko-dev-verify-token"
WHATSAPP_GRAPH_API_VERSION="v20.0"

# --- Email (Resend) ---
# Sin esto, los emails (invitación de equipo, recuperación de contraseña, aviso de contacto)
# no se mandan de verdad: quedan logueados en la consola del servidor (modo mock), igual que
# la IA y WhatsApp.
RESEND_API_KEY=""
EMAIL_FROM="Linko Agent <hola@linkoagent.com>"

# --- Mercado Pago (cobro recurrente) ---
# Sin MERCADOPAGO_ACCESS_TOKEN, el checkout de "Suscribirme" en /usage queda simulado: crea el
# link de pago mockeado pero no cobra nada real.
MERCADOPAGO_ACCESS_TOKEN=""
MERCADOPAGO_MOCK_MODE="true"

# --- Meta Embedded Signup (conectar WhatsApp con un click, sin tocar Phone Number ID/token) ---
# Requiere una app de Meta con Business Verification y App Review aprobados para
# whatsapp_business_management y whatsapp_business_messaging, más una Configuration ID creada
# en WhatsApp Manager > Embedded Signup. Sin esto, el botón de "Conectar con un click" queda
# deshabilitado y se sigue conectando el canal a mano con el formulario de siempre.
NEXT_PUBLIC_META_APP_ID=""
META_APP_SECRET=""
NEXT_PUBLIC_META_EMBEDDED_SIGNUP_CONFIG_ID=""

# --- Google Calendar (motor de acciones: reservar/cancelar/reprogramar turnos) ---
# Mismo criterio que el resto: sin GOOGLE_CALENDAR_CLIENT_ID, la conexión en /integrations queda
# simulada (se conecta al toque, sin salir de la app) y la disponibilidad se resuelve solo contra
# los turnos guardados localmente. La API de Calendar es gratis, no requiere facturación en Google
# Cloud. IMPORTANTE al crear el proyecto OAuth: pasarlo a "In production" en Google Cloud Console
# el mismo día (no hace falta esperar la verificación completa) — en estado "Testing" los
# refresh_token expiran a los 7 días sin excepción, y cada empresa cliente tendría que reconectar
# su calendario cada semana.
GOOGLE_CALENDAR_CLIENT_ID=""
GOOGLE_CALENDAR_CLIENT_SECRET=""
GOOGLE_CALENDAR_MOCK_MODE="true"
