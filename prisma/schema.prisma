generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  directUrl  = env("DIRECT_URL")
  extensions = [vector]
}

// ---------- Enums ----------

enum Role {
  SUPER_ADMIN
  COMPANY_ADMIN
  AGENT_HUMAN
}

enum PlanTier {
  STARTER
  PRO
  BUSINESS
  ENTERPRISE
}

enum ChannelType {
  WHATSAPP
  INSTAGRAM
  MESSENGER
}

enum ChannelStatus {
  DISCONNECTED
  CONNECTED
  ERROR
}

enum AgentType {
  ATENCION
  VENTAS
  SOPORTE
  RESERVAS
  POSTVENTA
  COBRANZAS
  PERSONALIZADO
}

enum ConversationStatus {
  NEW
  OPEN
  IN_PROGRESS
  PENDING
  HANDED_OFF
  RESOLVED
  CLOSED
}

enum SenderType {
  CUSTOMER
  AI
  HUMAN
  SYSTEM
}

enum KnowledgeSourceType {
  TEXT
  FAQ
  PDF
  URL
  DOCX
  SPREADSHEET
}

enum KnowledgeStatus {
  PENDING
  PROCESSING
  READY
  ERROR
}

enum LeadStage {
  NEW
  INTERESTED
  QUALIFIED
  QUOTED
  WON
  LOST
}

enum Priority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum IntegrationStatus {
  CONNECTED
  DISCONNECTED
  ERROR
}

enum AppointmentStatus {
  CONFIRMED
  CANCELLED
}

// ---------- Core / tenancy ----------

model User {
  id                  String    @id @default(cuid())
  name                String
  email               String    @unique
  passwordHash        String
  emailVerifiedAt     DateTime?
  notificationsSeenAt DateTime?
  createdAt           DateTime  @default(now())

  memberships           Membership[]
  notes                 Note[]
  auditLogs             AuditLog[]
  assignedConversations Conversation[]       @relation("AssignedHuman")
  handoffsReceived      HumanHandoff[]       @relation("HandoffToUser")
  passwordResetTokens   PasswordResetToken[]
  messageCorrections    MessageCorrection[]
}

/// Token de un solo uso para "recuperar contraseña" e "invitación de equipo" (crear la
/// contraseña inicial). Mismo mecanismo para los dos casos: se genera, se manda por email
/// con sendEmail(), y /reset-password lo consume.
model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  token     String    @unique
  purpose   String    @default("RESET") // "RESET" | "INVITE"
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Company {
  id                String   @id @default(cuid())
  name              String
  industry          String?
  logoUrl           String?
  brandTone         String?
  timezone          String   @default("America/Argentina/Buenos_Aires")
  businessHours     Json?
  outOfHoursMessage String?
  /// Teléfonos separados por coma, sin espacios, con código de país (ej. "5493511234567"),
  /// autorizados a ejecutar acciones administrativas (hoy: update_stock) por WhatsApp — para que
  /// un cliente cualquiera no pueda modificar el inventario por accidente o a propósito.
  staffPhoneNumbers String?
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())

  // ---- Configuración de agenda (src/lib/agenda) ----
  appointmentDurationMinutes  Int     @default(30)
  appointmentBufferMinutes    Int     @default(0)
  /// "HH:mm" o null si no hay pausa configurada. Los dos van juntos: o los dos null, o los dos con valor.
  lunchBreakStart             String?
  lunchBreakEnd               String?
  maxSimultaneousAppointments Int     @default(1)

  memberships        Membership[]
  subscription       Subscription?
  channels           Channel[]
  agents             Agent[]
  knowledgeSources   KnowledgeSource[]
  customers          Customer[]
  conversations      Conversation[]
  leads              Lead[]
  automations        Automation[]
  tags               Tag[]
  notes              Note[]
  aiUsageLogs        AiUsageLog[]
  auditLogs          AuditLog[]
  integrations       Integration[]
  webhookEvents      WebhookEvent[]
  appointments       Appointment[]
  products           Product[]
  messageCorrections MessageCorrection[]
  holidays           CompanyHoliday[]
}

model Membership {
  id        String   @id @default(cuid())
  userId    String
  companyId String
  role      Role
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([userId, companyId])
}

model Plan {
  id                    String   @id @default(cuid())
  tier                  PlanTier @unique
  name                  String
  priceUsd              Int
  setupFeeUsd           Int
  maxAgents             Int
  maxConversationsMonth Int
  maxChannels           Int
  maxUsers              Int

  subscriptions Subscription[]
}

model Subscription {
  id                String   @id @default(cuid())
  companyId         String   @unique
  planId            String
  status            String   @default("active")
  currentPeriodEnd  DateTime
  conversationsUsed Int      @default(0)
  tokensUsed        Int      @default(0)
  costUsd           Float    @default(0)
  mpPreapprovalId   String?  @unique
  createdAt         DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  plan    Plan    @relation(fields: [planId], references: [id])
}

// ---------- Channels & agents ----------

model Channel {
  id                 String        @id @default(cuid())
  companyId          String
  type               ChannelType
  status             ChannelStatus @default(DISCONNECTED)
  accountName        String?
  accountId          String?
  phoneNumberId      String?       @unique
  wabaId             String?
  accessToken        String?
  webhookVerifyToken String?
  /// Genérico: null para WhatsApp (token de sistema, no vence); Instagram vence a los 60 días.
  tokenExpiresAt     DateTime?
  /// Genérico: scopes OAuth otorgados, mismo criterio que Integration.scope.
  scope              String?
  /// Genérico: datos propios de cada proveedor que no ameritan columna propia (ej. Instagram:
  /// {username, followersCount, profilePictureUrl}).
  metadata           Json?
  connectedAt        DateTime?
  lastMessageAt      DateTime?
  lastError          String?
  createdAt          DateTime      @default(now())

  company       Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  agents        AgentChannel[]
  conversations Conversation[]

  @@index([companyId])
  /// Resolución de webhook por (tipo, id de cuenta) — análogo a phoneNumberId, pero genérico para
  /// cualquier canal que no tenga un identificador único propio como WhatsApp.
  @@unique([type, accountId])
}

model Agent {
  id             String    @id @default(cuid())
  companyId      String
  name           String
  type           AgentType
  objective      String?
  tone           String?
  instructions   String
  language       String    @default("es")
  isActive       Boolean   @default(true)
  activeHours    Json?
  handoffRules   String?
  actionsEnabled Boolean   @default(false)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  company            Company                @relation(fields: [companyId], references: [id], onDelete: Cascade)
  channels           AgentChannel[]
  knowledgeSources   AgentKnowledgeSource[]
  conversations      Conversation[]
  aiUsageLogs        AiUsageLog[]
  messageCorrections MessageCorrection[]

  @@index([companyId])
}

model AgentChannel {
  agentId   String
  channelId String
  /// Nullable: cuando no está seteado, se usa Agent.tone (mismo tono en todos los canales).
  toneOverride String?

  agent   Agent   @relation(fields: [agentId], references: [id], onDelete: Cascade)
  channel Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@id([agentId, channelId])
}

// ---------- Knowledge base ----------

model KnowledgeSource {
  id              String              @id @default(cuid())
  companyId       String
  name            String
  type            KnowledgeSourceType
  status          KnowledgeStatus     @default(PENDING)
  content         String?
  sourceUrl       String?
  uploadedAt      DateTime            @default(now())
  lastProcessedAt DateTime?
  errorMessage    String?

  company Company                @relation(fields: [companyId], references: [id], onDelete: Cascade)
  agents  AgentKnowledgeSource[]
  chunks  KnowledgeChunk[]

  @@index([companyId])
}

model AgentKnowledgeSource {
  agentId  String
  sourceId String

  agent  Agent           @relation(fields: [agentId], references: [id], onDelete: Cascade)
  source KnowledgeSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  @@id([agentId, sourceId])
}

model KnowledgeChunk {
  id         String                      @id @default(cuid())
  sourceId   String
  companyId  String
  content    String
  tokenCount Int                         @default(0)
  embedding  Unsupported("vector(768)")?
  createdAt  DateTime                    @default(now())

  source KnowledgeSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  @@index([companyId])
}

// ---------- Customers, conversations, messages ----------

model Customer {
  id            String      @id @default(cuid())
  companyId     String
  name          String?
  phone         String?
  channelType   ChannelType
  channelUserId String
  createdAt     DateTime    @default(now())
  lastContactAt DateTime    @default(now())

  company       Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  conversations Conversation[]
  leads         Lead[]
  notes         Note[]
  tags          CustomerTag[]
  appointments  Appointment[]

  @@unique([companyId, channelType, channelUserId])
}

model Conversation {
  id                String             @id @default(cuid())
  companyId         String
  channelId         String
  customerId        String
  agentId           String?
  assignedUserId    String?
  status            ConversationStatus @default(NEW)
  priority          Priority           @default(NORMAL)
  aiPaused          Boolean            @default(false)
  summary           String?
  detectedIntent    String?
  detectedSentiment String?
  lastMessageAt     DateTime           @default(now())
  createdAt         DateTime           @default(now())
  closedAt          DateTime?

  company      Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  channel      Channel             @relation(fields: [channelId], references: [id])
  customer     Customer            @relation(fields: [customerId], references: [id])
  agent        Agent?              @relation(fields: [agentId], references: [id])
  assignedUser User?               @relation("AssignedHuman", fields: [assignedUserId], references: [id])
  messages     Message[]
  notes        Note[]
  tags         ConversationTag[]
  handoffs     HumanHandoff[]
  appointments Appointment[]
  corrections  MessageCorrection[]

  @@index([companyId, status])
}

model Message {
  id                      String     @id @default(cuid())
  conversationId          String
  sender                  SenderType
  /// Si es un mensaje de voz transcripto, content = el texto transcripto (así el resto del
  /// pipeline de IA lo trata exactamente igual que un mensaje de texto, sin duplicar el dato).
  content                 String
  channelMessageId        String?
  promptTokens            Int?
  completionTokens        Int?
  costUsd                 Float?
  isVoiceMessage          Boolean    @default(false)
  /// ID del media en la Graph API de Meta (no la URL prefirmada, que expira en minutos) — sirve
  /// para volver a descargar el audio original mientras Meta lo conserve.
  audioMediaId            String?
  transcriptionLanguage   String?
  /// Heurística 0-1 derivada de los log-probs de Whisper, no una probabilidad real de acierto.
  transcriptionConfidence Float?
  /// Solo se genera si la transcripción es larga (ver TRANSCRIPTION_SUMMARY_THRESHOLD).
  transcriptionSummary    String?
  createdAt               DateTime   @default(now())

  conversation Conversation        @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  corrections  MessageCorrection[]

  @@index([conversationId])
}

enum CorrectionType {
  CORRECTION
  APPROVAL
}

/// Historial de aprendizaje: el dueño/equipo puede corregir una respuesta incorrecta de la IA
/// (se guarda como conocimiento nuevo automáticamente, ver addFaqKnowledgeEntry en
/// src/lib/ai/knowledge.ts) o aprobar una respuesta correcta (solo queda como registro de QA,
/// no genera conocimiento nuevo — aprobar no "enseña" nada que el agente no supiera ya).
model MessageCorrection {
  id               String         @id @default(cuid())
  companyId        String
  agentId          String?
  conversationId   String
  messageId        String
  type             CorrectionType
  customerMessage  String
  originalContent  String
  correctedContent String?
  createdByUserId  String
  createdAt        DateTime       @default(now())

  company      Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  agent        Agent?       @relation(fields: [agentId], references: [id])
  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  message      Message      @relation(fields: [messageId], references: [id], onDelete: Cascade)
  createdBy    User         @relation(fields: [createdByUserId], references: [id])

  @@index([companyId, createdAt])
}

// ---------- CRM (schema scaffold; UI simplificada en el MVP) ----------

model Lead {
  id             String    @id @default(cuid())
  companyId      String
  customerId     String
  stage          LeadStage @default(NEW)
  source         String?
  assignedUserId String?
  notes          String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  company  Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  customer Customer @relation(fields: [customerId], references: [id])

  @@index([companyId, stage])
}

model Automation {
  id             String   @id @default(cuid())
  companyId      String
  name           String
  conditionType  String
  conditionValue Json?
  actionType     String
  actionValue    Json?
  channelId      String?
  agentId        String?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
}

// ---------- IA, handoffs, tags, notas ----------

model AiUsageLog {
  id               String   @id @default(cuid())
  companyId        String
  agentId          String?
  conversationId   String?
  model            String
  promptTokens     Int
  completionTokens Int
  totalTokens      Int
  costUsd          Float
  createdAt        DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  agent   Agent?  @relation(fields: [agentId], references: [id])

  @@index([companyId, createdAt])
}

model HumanHandoff {
  id             String   @id @default(cuid())
  conversationId String
  fromAgentId    String?
  toUserId       String?
  reason         String?
  createdAt      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  toUser       User?        @relation("HandoffToUser", fields: [toUserId], references: [id])
}

model Tag {
  id        String @id @default(cuid())
  companyId String
  name      String
  color     String @default("#3B4CFF")

  company       Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  conversations ConversationTag[]
  customers     CustomerTag[]

  @@unique([companyId, name])
}

model ConversationTag {
  conversationId String
  tagId          String

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  tag          Tag          @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([conversationId, tagId])
}

model CustomerTag {
  customerId String
  tagId      String

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  tag      Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([customerId, tagId])
}

model Note {
  id             String   @id @default(cuid())
  companyId      String
  conversationId String?
  customerId     String?
  authorUserId   String
  body           String
  createdAt      DateTime @default(now())

  company      Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  conversation Conversation? @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  customer     Customer?     @relation(fields: [customerId], references: [id], onDelete: Cascade)
  author       User          @relation(fields: [authorUserId], references: [id])
}

// ---------- Integraciones / auditoría ----------

/// `provider` es un identificador libre (ej. "GOOGLE_CALENDAR") en vez de un enum, para no
/// requerir una migración cada vez que se suma un proveedor nuevo; se valida con un union
/// type de TypeScript en el código (ver src/lib/actions/integrations.ts).
model Integration {
  id             String            @id @default(cuid())
  companyId      String
  provider       String
  status         IntegrationStatus @default(DISCONNECTED)
  accountEmail   String?
  calendarId     String            @default("primary")
  /// Solo para provider = "GOOGLE_SHEETS". null hasta que el usuario pega la URL/ID de su Sheet
  /// después de conectar por OAuth (a diferencia de Calendar, acá no hay un "primary" por defecto).
  spreadsheetId  String?
  sheetName      String?           @default("Hoja1")
  accessToken    String?
  refreshToken   String?
  tokenExpiresAt DateTime?
  scope          String?
  lastSyncAt     DateTime?
  lastError      String?
  config         Json?
  createdAt      DateTime          @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, provider])
}

/// Reservas de turnos. Se guarda una copia local (en vez de consultar Google Calendar en
/// cada búsqueda) porque la API de Calendar no permite encontrar eventos por teléfono del
/// cliente sin un email de invitado. Reprogramar actualiza la misma fila (sigue CONFIRMED)
/// en vez de crear una fila nueva, para no tener ambigüedad al buscar el turno vigente.
model Appointment {
  id             String            @id @default(cuid())
  companyId      String
  customerId     String
  conversationId String?
  googleEventId  String
  startsAt       DateTime
  endsAt         DateTime
  status         AppointmentStatus @default(CONFIRMED)
  notes          String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  company      Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  customer     Customer      @relation(fields: [customerId], references: [id], onDelete: Cascade)
  conversation Conversation? @relation(fields: [conversationId], references: [id])

  // No hay @@unique acá a propósito: con maxSimultaneousAppointments configurable, puede haber
  // más de una fila CONFIRMED superpuesta en el mismo horario (ej. varias sillas de peluquería).
  // La protección contra doble-reserva por encima del máximo vive en una transacción Postgres
  // Serializable en src/lib/agenda/service.ts (cuenta overlaps reales, no igualdad de startsAt),
  // no en un constraint de DB — antes había un índice único parcial solo para status=CONFIRMED,
  // pero era incompatible con max>1 y además no detectaba solapamientos de duración variable.
  @@index([companyId, startsAt])
  @@index([companyId, customerId, status])
}

/// Feriados fijos (recurringYearly=true, se repiten todos los años comparando solo mes/día) y
/// vacaciones puntuales (recurringYearly=false, un rango [date, endDate] de un año específico).
/// Un solo modelo para los dos casos porque ambos son "bloquear estos días para reservar turnos".
model CompanyHoliday {
  id              String    @id @default(cuid())
  companyId       String
  date            DateTime  @db.Date
  endDate         DateTime? @db.Date
  label           String?
  recurringYearly Boolean   @default(false)
  createdAt       DateTime  @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
}

/// Inventario simple. Se carga a mano en /products por ahora (sincronización con Google
/// Sheets/Excel queda para una etapa posterior) — es la fuente que consultan/modifican los
/// tools de stock del agente (check_stock/update_stock).
/// Inventario simple. Atributos más allá de nombre/stock (precio, SKU, color, talle, etc.) se
/// guardan en customFields como pares label->valor libres, porque un negocio puede vender
/// productos, servicios, o cualquier otra cosa con sus propios atributos.
model Product {
  id           String   @id @default(cuid())
  companyId    String
  name         String
  stock        Int      @default(0)
  customFields Json     @default("{}")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([companyId, name])
}

model WebhookEvent {
  id          String    @id @default(cuid())
  companyId   String?
  channelId   String?
  provider    String
  payload     Json
  processedAt DateTime?
  error       String?
  createdAt   DateTime  @default(now())

  company Company? @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id         String   @id @default(cuid())
  companyId  String?
  userId     String?
  action     String
  entityType String?
  entityId   String?
  metadata   Json?
  createdAt  DateTime @default(now())

  company Company? @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user    User?    @relation(fields: [userId], references: [id])
}

// ---------- Landing comercial ----------

/// Leads del formulario de contacto de la landing (linkoagent.com). El envío del
/// email de notificación a hola@linkoagent.com se agrega en la etapa de Resend;
/// por ahora el registro queda guardado acá para no perder ningún lead.
model ContactRequest {
  id              String   @id @default(cuid())
  name            String
  company         String
  email           String
  phone           String?
  channel         String?
  monthlyMessages String?
  industry        String?
  message         String?
  handled         Boolean  @default(false)
  createdAt       DateTime @default(now())
}
