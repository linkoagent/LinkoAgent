generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [vector]
}

// ---------- Enums ----------

enum Role {
  SUPER_ADMIN
  COMPANY_ADMIN
  AGENT_HUMAN
}

enum PlanTier {
  STARTER
  PRO
  BUSINESS
  ENTERPRISE
}

enum ChannelType {
  WHATSAPP
  INSTAGRAM
  MESSENGER
}

enum ChannelStatus {
  DISCONNECTED
  CONNECTED
  ERROR
}

enum AgentType {
  ATENCION
  VENTAS
  SOPORTE
  RESERVAS
  POSTVENTA
  COBRANZAS
  PERSONALIZADO
}

enum ConversationStatus {
  NEW
  OPEN
  IN_PROGRESS
  PENDING
  HANDED_OFF
  RESOLVED
  CLOSED
}

enum SenderType {
  CUSTOMER
  AI
  HUMAN
  SYSTEM
}

enum KnowledgeSourceType {
  TEXT
  FAQ
  PDF
  URL
}

enum KnowledgeStatus {
  PENDING
  PROCESSING
  READY
  ERROR
}

enum LeadStage {
  NEW
  INTERESTED
  QUALIFIED
  QUOTED
  WON
  LOST
}

enum Priority {
  LOW
  NORMAL
  HIGH
  URGENT
}

// ---------- Core / tenancy ----------

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())

  memberships           Membership[]
  notes                 Note[]
  auditLogs              AuditLog[]
  assignedConversations Conversation[]  @relation("AssignedHuman")
  handoffsReceived       HumanHandoff[] @relation("HandoffToUser")
  passwordResetTokens   PasswordResetToken[]
}

/// Token de un solo uso para "recuperar contraseña" e "invitación de equipo" (crear la
/// contraseña inicial). Mismo mecanismo para los dos casos: se genera, se manda por email
/// con sendEmail(), y /reset-password lo consume.
model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  token     String    @unique
  purpose   String    @default("RESET") // "RESET" | "INVITE"
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Company {
  id                String   @id @default(cuid())
  name              String
  industry          String?
  logoUrl           String?
  brandTone         String?
  timezone          String   @default("America/Argentina/Buenos_Aires")
  businessHours     Json?
  outOfHoursMessage String?
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())

  memberships      Membership[]
  subscription     Subscription?
  channels         Channel[]
  agents           Agent[]
  knowledgeSources KnowledgeSource[]
  customers        Customer[]
  conversations    Conversation[]
  leads            Lead[]
  automations      Automation[]
  tags             Tag[]
  notes            Note[]
  aiUsageLogs      AiUsageLog[]
  auditLogs        AuditLog[]
  integrations     Integration[]
  webhookEvents    WebhookEvent[]
}

model Membership {
  id        String   @id @default(cuid())
  userId    String
  companyId String
  role      Role
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([userId, companyId])
}

model Plan {
  id                    String   @id @default(cuid())
  tier                  PlanTier @unique
  name                  String
  priceUsd              Int
  setupFeeUsd           Int
  maxAgents             Int
  maxConversationsMonth Int
  maxChannels           Int
  maxUsers              Int

  subscriptions Subscription[]
}

model Subscription {
  id                String   @id @default(cuid())
  companyId         String   @unique
  planId            String
  status            String   @default("active")
  currentPeriodEnd  DateTime
  conversationsUsed Int      @default(0)
  tokensUsed        Int      @default(0)
  costUsd           Float    @default(0)
  createdAt         DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  plan    Plan    @relation(fields: [planId], references: [id])
}

// ---------- Channels & agents ----------

model Channel {
  id                 String        @id @default(cuid())
  companyId          String
  type               ChannelType
  status             ChannelStatus @default(DISCONNECTED)
  accountName        String?
  accountId          String?
  phoneNumberId      String?       @unique
  wabaId             String?
  accessToken        String?
  webhookVerifyToken String?
  connectedAt        DateTime?
  lastMessageAt      DateTime?
  lastError          String?
  createdAt          DateTime      @default(now())

  company       Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  agents        AgentChannel[]
  conversations Conversation[]

  @@index([companyId])
}

model Agent {
  id           String    @id @default(cuid())
  companyId    String
  name         String
  type         AgentType
  objective    String?
  tone         String?
  instructions String
  language     String    @default("es")
  isActive     Boolean   @default(true)
  activeHours  Json?
  handoffRules String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  company          Company                @relation(fields: [companyId], references: [id], onDelete: Cascade)
  channels         AgentChannel[]
  knowledgeSources AgentKnowledgeSource[]
  conversations    Conversation[]
  aiUsageLogs      AiUsageLog[]

  @@index([companyId])
}

model AgentChannel {
  agentId   String
  channelId String

  agent   Agent   @relation(fields: [agentId], references: [id], onDelete: Cascade)
  channel Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@id([agentId, channelId])
}

// ---------- Knowledge base ----------

model KnowledgeSource {
  id              String              @id @default(cuid())
  companyId       String
  name            String
  type            KnowledgeSourceType
  status          KnowledgeStatus     @default(PENDING)
  content         String?
  sourceUrl       String?
  uploadedAt      DateTime            @default(now())
  lastProcessedAt DateTime?
  errorMessage    String?

  company Company                @relation(fields: [companyId], references: [id], onDelete: Cascade)
  agents  AgentKnowledgeSource[]
  chunks  KnowledgeChunk[]

  @@index([companyId])
}

model AgentKnowledgeSource {
  agentId  String
  sourceId String

  agent  Agent           @relation(fields: [agentId], references: [id], onDelete: Cascade)
  source KnowledgeSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  @@id([agentId, sourceId])
}

model KnowledgeChunk {
  id         String                       @id @default(cuid())
  sourceId   String
  companyId  String
  content    String
  tokenCount Int                          @default(0)
  embedding  Unsupported("vector(1536)")?
  createdAt  DateTime                     @default(now())

  source KnowledgeSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  @@index([companyId])
}

// ---------- Customers, conversations, messages ----------

model Customer {
  id            String      @id @default(cuid())
  companyId     String
  name          String?
  phone         String?
  channelType   ChannelType
  channelUserId String
  createdAt     DateTime    @default(now())
  lastContactAt DateTime    @default(now())

  company       Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  conversations Conversation[]
  leads         Lead[]
  notes         Note[]
  tags          CustomerTag[]

  @@unique([companyId, channelType, channelUserId])
}

model Conversation {
  id                String             @id @default(cuid())
  companyId         String
  channelId         String
  customerId        String
  agentId           String?
  assignedUserId    String?
  status            ConversationStatus @default(NEW)
  priority          Priority           @default(NORMAL)
  aiPaused          Boolean            @default(false)
  summary           String?
  detectedIntent    String?
  detectedSentiment String?
  lastMessageAt     DateTime           @default(now())
  createdAt         DateTime           @default(now())
  closedAt          DateTime?

  company      Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  channel      Channel           @relation(fields: [channelId], references: [id])
  customer     Customer          @relation(fields: [customerId], references: [id])
  agent        Agent?            @relation(fields: [agentId], references: [id])
  assignedUser User?             @relation("AssignedHuman", fields: [assignedUserId], references: [id])
  messages     Message[]
  notes        Note[]
  tags         ConversationTag[]
  handoffs     HumanHandoff[]

  @@index([companyId, status])
}

model Message {
  id               String     @id @default(cuid())
  conversationId   String
  sender           SenderType
  content          String
  channelMessageId String?
  promptTokens     Int?
  completionTokens Int?
  costUsd          Float?
  createdAt        DateTime   @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
}

// ---------- CRM (schema scaffold; UI simplificada en el MVP) ----------

model Lead {
  id             String    @id @default(cuid())
  companyId      String
  customerId     String
  stage          LeadStage @default(NEW)
  source         String?
  assignedUserId String?
  notes          String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  company  Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  customer Customer @relation(fields: [customerId], references: [id])

  @@index([companyId, stage])
}

model Automation {
  id             String   @id @default(cuid())
  companyId      String
  name           String
  conditionType  String
  conditionValue Json?
  actionType     String
  actionValue    Json?
  channelId      String?
  agentId        String?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
}

// ---------- IA, handoffs, tags, notas ----------

model AiUsageLog {
  id               String   @id @default(cuid())
  companyId        String
  agentId          String?
  conversationId   String?
  model            String
  promptTokens     Int
  completionTokens Int
  totalTokens      Int
  costUsd          Float
  createdAt        DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  agent   Agent?  @relation(fields: [agentId], references: [id])

  @@index([companyId, createdAt])
}

model HumanHandoff {
  id             String   @id @default(cuid())
  conversationId String
  fromAgentId    String?
  toUserId       String?
  reason         String?
  createdAt      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  toUser       User?        @relation("HandoffToUser", fields: [toUserId], references: [id])
}

model Tag {
  id        String @id @default(cuid())
  companyId String
  name      String
  color     String @default("#3B4CFF")

  company       Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  conversations ConversationTag[]
  customers     CustomerTag[]

  @@unique([companyId, name])
}

model ConversationTag {
  conversationId String
  tagId          String

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  tag          Tag          @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([conversationId, tagId])
}

model CustomerTag {
  customerId String
  tagId      String

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  tag      Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([customerId, tagId])
}

model Note {
  id             String   @id @default(cuid())
  companyId      String
  conversationId String?
  customerId     String?
  authorUserId   String
  body           String
  createdAt      DateTime @default(now())

  company      Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  conversation Conversation? @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  customer     Customer?     @relation(fields: [customerId], references: [id], onDelete: Cascade)
  author       User          @relation(fields: [authorUserId], references: [id])
}

// ---------- Integraciones / auditoría (scaffold) ----------

model Integration {
  id        String   @id @default(cuid())
  companyId String
  provider  String
  config    Json?
  createdAt DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model WebhookEvent {
  id          String    @id @default(cuid())
  companyId   String?
  channelId   String?
  provider    String
  payload     Json
  processedAt DateTime?
  error       String?
  createdAt   DateTime  @default(now())

  company Company? @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id         String   @id @default(cuid())
  companyId  String?
  userId     String?
  action     String
  entityType String?
  entityId   String?
  metadata   Json?
  createdAt  DateTime @default(now())

  company Company? @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user    User?    @relation(fields: [userId], references: [id])
}

// ---------- Landing comercial ----------

/// Leads del formulario de contacto de la landing (linkoagent.com). El envío del
/// email de notificación a hola@linkoagent.com se agrega en la etapa de Resend;
/// por ahora el registro queda guardado acá para no perder ningún lead.
model ContactRequest {
  id              String   @id @default(cuid())
  name            String
  company         String
  email           String
  phone           String?
  channel         String?
  monthlyMessages String?
  industry        String?
  message         String?
  handled         Boolean  @default(false)
  createdAt       DateTime @default(now())
}
